PORT=5000
NODE_ENV=development

# IMPORTANT: Fill these in locally. Do NOT commit real values.
MONGO_URI=REPLACE_WITH_YOUR_MONGO_URI
JWT_SECRET=REPLACE_WITH_64_CHAR_RANDOM_HEX
ADMIN_SECRET_KEY=REPLACE_WITH_STRONG_ADMIN_KEY

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
GEMINI_API_KEY=
ONLINE_COMPILER_API_KEY=
ONLINE_COMPILER_CLIENT_ID=

SANDBOX_IMAGE=cic-sandbox:latest

# ──────────────────────────────────────────────────────────────
# Production Deployment Variables
# Set these in your deployment platform (Render, Railway, etc.)
# ──────────────────────────────────────────────────────────────

# Set to 'production' in production environment
# NODE_ENV=production

# Comma-separated list of allowed frontend origins for CORS (production only)
# Example: https://your-frontend.onrender.com,https://yourdomain.com
ALLOWED_ORIGINS=

# Frontend URL (used for CORS, email links, etc.)
# Example: https://your-frontend.onrender.com
FRONTEND_URL=