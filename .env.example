# Frontend Environment Variables (Vite)
# Copy to .env.local for local development
# For production deployment, set these in your hosting platform (Vercel, Netlify, etc.)

# Backend API URL - Set this to your deployed backend URL
# Development: leave empty to use Vite proxy (/api -> http://localhost:5000)
# Production: set to your backend URL (e.g., https://api.yourdomain.com)
VITE_API_URL=